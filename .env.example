# Public API origin (no trailing slash). Vite exposes only variables prefixed with VITE_.
VITE_API_BASE_URL=https://myticket-api.kat-jr.com

# Reads: use "mock" until GET routes exist in the Postman export; "api" enables live GETs where paths are defined in code.
VITE_ADMIN_READS_SOURCE=mock

# When true, sign-in accepts the legacy demo email heuristic without calling the API.
VITE_ALLOW_DEMO_AUTH=false

# Optional: some deployments require phone/otp on admin login (see Postman body).
# VITE_ADMIN_LOGIN_PHONE=
# VITE_ADMIN_LOGIN_OTP=
